# CODEX·IA Environment Variables
# Copy to .env and fill in values

# Database
DB_PATH=./data/codexia.db

# Vercel deployment
VERCEL_URL=https://codexia.corpusia.net

# DOF API (SIDOF)
SIDOF_BASE_URL=https://sidof.segob.gob.mx

# SCJN Bicentenario API
SCJN_API_URL=https://bicentenario.scjn.gob.mx

# Ingest settings
INGEST_BATCH_SIZE=100
INGEST_LOG_LEVEL=info
CAMARA_ZIP_URL=https://www.diputados.gob.mx/LeyesBiblio/zip.htm

# CORPUSIA integration
CORPUSIA_API_URL=https://api.corpusia.net
CORPUSIA_API_KEY=
